# ============================================================
# APP
# ============================================================
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME="Restaurant AI"
NODE_ENV=development

# ============================================================
# DATABASE (Neon / Supabase PostgreSQL)
# ============================================================
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/restaurant_saas?sslmode=require"

# ============================================================
# REDIS (Upstash)
# ============================================================
UPSTASH_REDIS_REST_URL="https://YOUR_ENDPOINT.upstash.io"
UPSTASH_REDIS_REST_TOKEN="YOUR_TOKEN"

# ============================================================
# AUTHENTICATION
# ============================================================
JWT_SECRET="your-super-secret-jwt-key-minimum-32-characters"
NEXTAUTH_SECRET="your-nextauth-secret-minimum-32-characters"
NEXTAUTH_URL=http://localhost:3000

# ============================================================
# OPENAI
# ============================================================
OPENAI_API_KEY="sk-..."
OPENAI_MODEL="gpt-4o"
OPENAI_EMBEDDING_MODEL="text-embedding-3-small"

# ============================================================
# PINECONE (Vector Database)
# ============================================================
PINECONE_API_KEY="your-pinecone-api-key"
PINECONE_INDEX="restaurant-knowledge"
PINECONE_ENVIRONMENT="us-east-1"

# ============================================================
# GOOGLE APIs
# ============================================================
GOOGLE_CLIENT_ID="your-google-client-id.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="your-google-client-secret"
GOOGLE_REDIRECT_URI="http://localhost:3000/api/google/callback"

# Service Account (for server-side Google APIs)
GOOGLE_SERVICE_ACCOUNT_EMAIL="service-account@project.iam.gserviceaccount.com"
GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"

# Google Sheets
GOOGLE_SHEETS_SPREADSHEET_ID="your-spreadsheet-id"

# ============================================================
# EMAIL (Resend)
# ============================================================
RESEND_API_KEY="re_..."
EMAIL_FROM="Restaurant AI <noreply@yourrestaurant.com>"
ADMIN_EMAIL="admin@yourrestaurant.com"

# ============================================================
# RATE LIMITING
# ============================================================
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW_MS=60000
